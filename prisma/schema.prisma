datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Author {
  id          Int       @id @default(autoincrement())
  name        String
  litPeriod   String?
  dateBorn    DateTime?
  dateDeath   DateTime?
  nationality String?
  bio         String?
  books       Book[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  books Book[]
  @@index([name])     
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  quantity      Int      @default(1)
  authorId      Int
  categoryId    Int
  publisherName String
  isbn          String?  @unique
  isAviable     Boolean  @default(true)
  dateCreated   DateTime @default(now())
  isBorrowed    Boolean  @default(false)
  publishedYear Int?
  description   String?
  coverImageUrl String?
  language      String?

  author   Author   @relation(fields: [authorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  orders   Order[]

  @@index([title])                
  @@index([authorId])             
  @@index([categoryId])           
  @@index([publishedYear])        
}

model Account {
  id         Int      @id @default(autoincrement())
  name       String
  username   String   @unique
  email      String   @unique
  password   String
  role       Role     @default(STUDENT)
  dateJoined DateTime @default(now())
  isActive   Boolean  @default(true)

  orders Order[]
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model Order {
  id        Int         @id @default(autoincrement())
  accountId Int
  bookId    Int
  createdAt DateTime    @default(now())
  status    OrderStatus @default(PENDING)

  account Account @relation(fields: [accountId], references: [id])
  book    Book    @relation(fields: [bookId], references: [id])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}
